# Docker Compose — copy to .env and fill in values before running docker compose up
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=change_me

# Production only
FRONTEND_URL=
VITE_API_URL=
# File mount approach (standard Docker):
GOOGLE_SERVICE_ACCOUNT_PATH=/path/to/cyf-service-account.json
# Env var approach (Coolify / no file access): base64-encode the JSON file contents:
#   base64 -i cyf-service-account.json | tr -d '\n'
# Then paste the result here:
GOOGLE_SERVICE_ACCOUNT_JSON=
